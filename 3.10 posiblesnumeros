	leer num2
	escribir "Ingrese el tercer número:"
	leer num3
	escribir "Ingrese el cuarto número:"
	leer num4
	
	mayor = num1
    
    Si num2 > mayor Entonces
		mayor = num2
    FinSi
    Si num3 > mayor  Entonces
        mayor = num3
    FinSi
    Si num4 > mayor Entonces
        mayor = num4
